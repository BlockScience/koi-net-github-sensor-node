# Required for KOI-net private key encryption/decryption
PRIV_KEY_PASSWORD=change_me

# Optional GitHub token. Used when github.api_token is empty.
GITHUB_API_TOKEN=

# Optional comma-separated owner/repo list. Example: BlockScience/rid-lib,octocat/Hello-World
GITHUB_REPOSITORIES=

# Optional overrides
GITHUB_POLL_INTERVAL_SECONDS=
GITHUB_STATE_PATH=

# Optional coordinator overrides
COORDINATOR_RID=
COORDINATOR_URL=http://127.0.0.1:8080/koi-net
